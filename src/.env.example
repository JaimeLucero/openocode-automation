# Neon Database Connection
# Get from Neon console: https://console.neon.tech
NEON_CONNECTION_STRING=postgresql://username:password@host.neon.tech/dbname?sslmode=require

# FastAPI Server
HOST=0.0.0.0
PORT=8000

# OpenCode API Key (optional)
OPENCODE_API_KEY=your_api_key_here

# Agent Models
PLANNER_MODEL=kimi-k2.5
BUILDER_MODEL=kimi-k2.5
TESTER_MODEL=kimi-k2.5

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id